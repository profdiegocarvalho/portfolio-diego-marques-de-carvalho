rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isResearcher() {
      return isSignedIn() && exists(/databases/$(database)/documents/researchers/$(request.auth.uid));
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Researchers Collection
    match /researchers/{userId} {
      allow get: if isSignedIn() && request.auth.uid == userId;
      allow create: if isSignedIn() && request.auth.uid == userId 
                    && request.resource.data.keys().hasAll(['userId', 'email', 'name'])
                    && request.resource.data.keys().size() == 3;
      allow update: if isSignedIn() && request.auth.uid == userId
                    && request.resource.data.userId == resource.data.userId;
    }

    // Patients Collection
    match /patients/{patientId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() 
                            && isValidId(patientId)
                            && request.resource.data.keys().hasAll(['id', 'initials', 'diagnosisDate'])
                            && request.resource.data.id == patientId;
      allow delete: if false; // Regulatory requirement for ELA research
      
      // Clinical Entries Subcollection
      match /entries/{entryId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() 
                      && isValidId(entryId)
                      && request.resource.data.patientId == patientId
                      && request.resource.data.keys().hasAll(['patientId', 'timestamp', 'alsfrs_total']);
        allow update: if isSignedIn() 
                      && request.resource.data.patientId == resource.data.patientId;
      }
    }
  }
}
